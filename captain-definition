{
  "schemaVersion": 2,
  "dockerfileLines": [
    "FROM node:18-alpine",
    "RUN mkdir -p /usr/src/app",
    "WORKDIR /usr/src/app",
    "COPY ./package.json ./yarn.lock /usr/src/app/",
    "RUN yarn install --frozen-lockfile",
    "COPY ./ /usr/src/app",
    "RUN yarn build",
    "ENV NODE_ENV production",
    "ENV PORT 80",
    "EXPOSE 80",
    "CMD [ \"yarn\", \"start\" ]"
  ]
}
